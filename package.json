{
  "name": "jirehs-flashcards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "frontend:dev": "nx run frontend:dev",
    "frontend:build": "nx run frontend:build",
    "frontend:test": "nx run frontend:test",
    "frontend:test:coverage": "nx run frontend:test:coverage",
    "desktop:dev": "nx run desktop:dev",
    "desktop:build": "nx run desktop:build",
    "ci": "pnpm frontend:test -- --run && pnpm frontend:build && cargo clippy --workspace -- -D warnings && cargo test --workspace"
  },
  "devDependencies": {
    "nx": "^20.0.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
